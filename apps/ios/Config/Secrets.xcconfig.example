// Copy to Secrets.xcconfig (gitignored) and fill in your Supabase credentials.
// Xcode → Project → Info → Configurations → set Debug/Release to Secrets.xcconfig

MARVI_SUPABASE_URL = https:/$()/YOUR_PROJECT_REF.supabase.co
MARVI_SUPABASE_ANON_KEY = your-anon-public-key
MARVI_API_MODE = supabase

// Injected into Info.plist at build time
INFOPLIST_KEY_MARVI_SUPABASE_URL = $(MARVI_SUPABASE_URL)
INFOPLIST_KEY_MARVI_SUPABASE_ANON_KEY = $(MARVI_SUPABASE_ANON_KEY)
INFOPLIST_KEY_MARVI_API_MODE = $(MARVI_API_MODE)
