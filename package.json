{
  "name": "marvi-society",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=@marvi-society/web",
    "web:build": "npm run build --workspace=@marvi-society/web",
    "health": "bash scripts/check-health.sh",
    "db:combine": "bash infra/supabase/scripts/combine-migrations.sh",
    "db:push": "bash scripts/release/sync-database.sh",
    "db:bootstrap": "bash scripts/bootstrap-supabase-remote.sh",
    "status": "bash scripts/release/status.sh",
    "verify": "bash scripts/release/verify.sh",
    "sync": "bash scripts/release/full-sync.sh",
    "sync:github": "bash scripts/release/sync-github.sh",
    "rollback": "bash scripts/release/rollback.sh",
    "release": "bash scripts/release/record-release.sh",
    "setup:hooks": "bash scripts/setup-githooks.sh",
    "ops": "bash scripts/marvi"
  }
}
