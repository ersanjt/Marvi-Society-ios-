#!/bin/bash
# Warn if migrations/manifest drift before push. Skip with: MARVI_SKIP_HOOKS=1 git push
set -euo pipefail

if [[ "${MARVI_SKIP_HOOKS:-0}" == "1" ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "pre-push: checking migration manifest..."
bash "$REPO_ROOT/infra/supabase/scripts/combine-migrations.sh" >/dev/null

if ! git -C "$REPO_ROOT" diff --quiet -- release/manifest.json infra/supabase/ALL_MIGRATIONS_COMBINED.sql; then
  echo "pre-push: WARNING — migration files changed. Run: npm run db:combine && git add release/manifest.json infra/supabase/ALL_MIGRATIONS_COMBINED.sql"
fi

echo "pre-push: OK"
exit 0
